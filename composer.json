{
    "name": "codraw/aws-tool-kit",
    "description": "This package offer a few AWS tool kit.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "draw",
        "aws"
    ],
    "require": {
        "php": "^8.5",
        "aws/aws-sdk-php": "^3.171",
        "psr/log": "^3",
        "symfony/console": "^6.4.0",
        "symfony/event-dispatcher": "^6.4.0",
        "symfony/http-client-contracts": "^3.4"
    },
    "require-dev": {
        "codraw/core": "^0.39",
        "codraw/dependency-injection": "^0.39",
        "codraw/tester": "^0.39",
        "phpunit/phpunit": "^11.3 || ^12.0",
        "symfony/cache": "^6.4.0",
        "symfony/http-client": "^6.4.0"
    },
    "conflict": {
        "guzzlehttp/guzzle": "<6"
    },
    "suggest": {
        "aws/aws-sdk-php-symfony": "To configure aws-sdk-php into symfony",
        "symfony/http-client": "To provide a HttpClientInterface implementation for the IMDS clients"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Draw\\Component\\AwsToolKit\\": ""
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.39-dev"
        }
    },
    "replace": {
        "draw/aws-tool-kit": "self.version"
    }
}
